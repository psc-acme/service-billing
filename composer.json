{
    "name": "psc-acme/service-billing",
    "description": "Package service-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ServiceBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/serializer": "^7.0",
        "symfony/filesystem": "^7.0",
        "aws/aws-sdk-php": "^3.332",
        "illuminate/support": "^11.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}